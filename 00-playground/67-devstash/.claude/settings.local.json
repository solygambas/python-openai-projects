{
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": ["neon"],
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node --experimental-strip-types $CLAUDE_PROJECT_DIR/.claude/hooks/prettier-normalize.ts"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node --experimental-strip-types $CLAUDE_PROJECT_DIR/.claude/hooks/prettier-write.ts"
          }
        ]
      }
    ]
  }
}
