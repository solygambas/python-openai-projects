{
  "permissions": {
    "allow": [
      "Bash(git checkout:*)",
      "Bash(npm run:*)",
      "WebFetch(domain:groq.com)",
      "WebFetch(domain:console.groq.com)"
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "neon"
  ],
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node --experimental-strip-types $CLAUDE_PROJECT_DIR/.claude/hooks/log-pre-edit.ts"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "node --experimental-strip-types $CLAUDE_PROJECT_DIR/.claude/hooks/prettier-write.ts"
          }
        ]
      }
    ]
  }
}
