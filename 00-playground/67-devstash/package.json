{
  "name": "67-devstash",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "lint:fix": "eslint . --fix",
    "type-check": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "preclean": "npm run format && npm run lint:fix",
    "validate": "npm run preclean && npm run type-check",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "prisma:base": "node --env-file=.env node_modules/prisma/build/index.js",
    "db:migrate": "npm run prisma:base -- migrate dev",
    "db:deploy": "npm run prisma:base -- migrate deploy",
    "db:seed": "npm run prisma:base -- db seed",
    "db:status": "npm run prisma:base -- migrate status",
    "db:studio": "npm run prisma:base -- studio",
    "db:test": "node --experimental-strip-types --env-file=.env scripts/test-db.ts",
    "db:clean-users": "node --experimental-strip-types --env-file=.env scripts/clean-users.ts",
    "stripe": ".\\bin\\stripe.exe",
    "stripe:login": "npm run stripe -- login",
    "stripe:listen": "npm run stripe -- listen --forward-to localhost:3000/api/webhooks/stripe",
    "postinstall": "npm run prisma:base -- generate"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@aws-sdk/client-s3": "^3.1016.0",
    "@base-ui/react": "^1.3.0",
    "@hookform/resolvers": "^5.2.2",
    "@monaco-editor/react": "^4.7.0",
    "@neondatabase/serverless": "^1.0.2",
    "@prisma/adapter-neon": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "groq-sdk": "^1.1.2",
    "lucide-react": "^0.577.0",
    "next": "16.1.7",
    "next-auth": "^5.0.0-beta.30",
    "prisma": "^7.5.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.72.0",
    "react-markdown": "^10.1.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "resend": "^6.9.4",
    "shadcn": "^4.0.8",
    "sonner": "^2.0.7",
    "stripe": "^22.0.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "ws": "^8.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.19.37",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.1",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.7",
    "prettier": "^3.8.1",
    "tailwindcss": "^4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.1"
  }
}
