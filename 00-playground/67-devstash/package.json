{
  "name": "67-devstash",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "prisma:base": "node --env-file=.env node_modules/prisma/build/index.js",
    "db:migrate": "npm run prisma:base -- migrate dev",
    "db:deploy": "npm run prisma:base -- migrate deploy",
    "db:seed": "npm run prisma:base -- db seed",
    "db:status": "npm run prisma:base -- migrate status",
    "db:studio": "npm run prisma:base -- studio",
    "db:test": "node --experimental-strip-types --env-file=.env scripts/test-db.ts",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@base-ui/react": "^1.3.0",
    "@neondatabase/serverless": "^1.0.2",
